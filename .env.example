# ── Required ─────────────────────────────────────────────────
# URL of the real service AgentGuard proxies to
AGENTGUARD_UPSTREAM_URL=http://localhost:8080

# Your existing Nascentist Supabase project
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── Optional ─────────────────────────────────────────────────
# AgentGuard config
AGENTGUARD_PORT=7777
AGENTGUARD_POLICY_FILE=./policy.yaml
AGENTGUARD_SQLITE_PATH=./audit.db
AGENTGUARD_ENV=development

# Nascentist memory integration (adds context to policy decisions)
NASCENTIST_MEMORY_URL=https://nascentist.ai
NASCENTIST_INTERNAL_KEY=your_internal_key_here
